{
  "name": "feca-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "postinstall": "prisma generate",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "check": "tsc --noEmit -p tsconfig.build.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "db:up": "docker compose up -d postgres",
    "db:backfill:city-ids": "ts-node src/scripts/backfill-city-ids.ts --write",
    "db:backfill:city-ids:dry": "ts-node src/scripts/backfill-city-ids.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.0.3",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.3",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.6.0",
    "cache-manager": "^6.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^10.6.2",
    "prisma": "^6.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
