PROJECT_NAME=feca
APP_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=ops@example.com

POSTGRES_DB=feca_backend
POSTGRES_USER=feca
POSTGRES_PASSWORD=replace-with-a-long-random-password

NODE_ENV=production
PORT=3001
AUTH_JWT_ACCESS_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
GOOGLE_MAPS_API_KEY=replace-with-google-maps-server-key
GOOGLE_OAUTH_WEB_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
GOOGLE_PLACES_COUNTRY=uy
GOOGLE_PLACES_LANGUAGE=es
GOOGLE_PLACES_RADIUS_METERS=5000
CACHE_TTL_MS=300000
CACHE_MAX_ITEMS=500
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=60
CORS_ALLOWED_ORIGINS=
FECA_ADMIN_EMAILS=
TRUST_PROXY=true
